#!/usr/bin/env python3
"""
zcode-mcp-server — 把 headless ZCode 能力暴露为标准 MCP server

通过 stdio 实现 Model Context Protocol, 让任何 MCP client (zcode 自身、
Claude Code、Cursor 等) 能标准化地发现并调用 headless zcode。

暴露的 tools:
  1. get_zcode_capabilities — 返回 headless zcode 完整能力清单 (JSON)
  2. zcode_review           — 直接调 zcode 审查代码 (封装 --prompt + --attach + --mode plan)

协议: MCP over stdio (JSON-RPC 2.0, 每行一条消息)
日志: 全部走 stderr (绝不污染 stdout 协议流)

依赖: 仅 Python3 标准库 (零第三方依赖)
"""

import fcntl
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path

# zcode-agent-help 的路径 (能力发现的数据源)
# 优先解析仓库相邻路径 (../agent-help/zcode-agent-help), 让"从仓库直接运行"读到同版本;
# 不存在则 fallback 到安装态 ~/.local/bin (修复 P2: 原默认指向安装态, 仓库运行读到旧版)
_REPO_AGENT_HELP = Path(__file__).resolve().parent.parent / "agent-help" / "zcode-agent-help"
_DEFAULT_AGENT_HELP = str(_REPO_AGENT_HELP) if _REPO_AGENT_HELP.exists() else str(
    Path.home() / ".local" / "bin" / "zcode-agent-help"
)
AGENT_HELP_BIN = os.environ.get("ZCODE_AGENT_HELP_BIN", _DEFAULT_AGENT_HELP)
ZCODE_BIN = os.environ.get("ZCODE_BIN", "zcode")

# MCP 协议版本
PROTOCOL_VERSION = "2024-11-05"
SERVER_INFO = {"name": "zcode-mcp-server", "version": "1.0.0"}


def log(msg):
    """日志走 stderr, 不污染 stdout 协议流"""
    print(f"[zcode-mcp] {msg}", file=sys.stderr, flush=True)


def load_zcode_credentials():
    """从 ~/.zcode/v2/config.json 动态读取凭证 (不明文存储)。

    MCP server 被 zcode 以子进程方式 spawn, 不会继承 shell 的环境变量,
    所以必须自己从配置文件读取 model/baseURL/apiKey 注入给 zcode 子进程。

    NOTE: 本函数源自 shared/credentials.py (权威实现), 修改时请同步。
    """
    cfg_path = Path.home() / ".zcode" / "v2" / "config.json"
    try:
        with open(cfg_path) as f:
            cfg = json.load(f)
        for _pid, p in cfg.get("provider", {}).items():
            if p.get("enabled"):
                opts = p.get("options", {})
                models = p.get("models", {})
                model_id = next(iter(models)) if models else "GLM-5.2"
                return {
                    "ZCODE_MODEL": model_id,
                    "ZCODE_BASE_URL": opts.get("baseURL", ""),
                    "ANTHROPIC_API_KEY": opts.get("apiKey", ""),
                }
    except Exception as e:
        log(f"读取凭证失败: {e}")
    return {}


# ============================================================
# provider 错误解析 (源自 shared/provider_error.py, 单文件可独立运行故内嵌)
# 识别 zcode headless 调用返回的 provider 限流/配额错误, 用于有限重试。
# 修改时请同步 shared/provider_error.py。
# ============================================================
def _parse_provider_error(text):
    """分析 zcode 调用输出文本, 返回 {is_rate_limit, is_quota, retry_after_sec, error_kind}。"""
    if not text:
        return {"is_rate_limit": False, "is_quota": False, "retry_after_sec": None, "error_kind": "unknown"}
    sample = text if len(text) <= 2000 else text[:2000]
    lower = sample.lower()
    retry_after = _extract_retry_after(sample)

    # 配额耗尽 (不可短期重试)
    quota_pats = [r"\bquota\b", r"配额", r"额度", r"余额", r"exceeded.*limit", r"insufficient.*credit"]
    if any(re.search(p, lower) for p in quota_pats):
        return {"is_rate_limit": False, "is_quota": True, "retry_after_sec": retry_after, "error_kind": "quota"}

    # 限流 (可安全重试)
    rl_pats = [r"\b429\b", r"too many requests", r"ratelimit", r"rate_limit",
               r"rate limit", r"\b1302\b", r"请求过于频繁", r"频繁", r"slow\s*down", r"throttl"]
    if any(re.search(p, lower) for p in rl_pats) or retry_after is not None:
        return {"is_rate_limit": True, "is_quota": False, "retry_after_sec": retry_after, "error_kind": "rate_limit"}

    return {"is_rate_limit": False, "is_quota": False, "retry_after_sec": None, "error_kind": "unknown"}


def _extract_retry_after(sample):
    """从错误文本提取 retry-after 秒数 (限 [1,300])。"""
    for pat in [r'retry-?after\s*[:=]\s*"?(\d+)', r'retryAfter"\s*:\s*"?(\d+)',
                r'(\d+)\s*秒[后以]', r'try\s+again\s+in\s+(\d+)']:
        m = re.search(pat, sample, re.IGNORECASE)
        if m:
            try:
                return max(1, min(300, int(m.group(1))))
            except (TypeError, ValueError):
                pass
    return None


# ============================================================
# 进程级文件锁 (防并发 headless review 触发限流, issue #3 子项3)
# 多个 MCP client 进程会各自 spawn zcode; 文件锁串行化 review 调用。
# 默认开, ZCODE_BRIDGE_REVIEW_LOCK=0 关闭。
# ============================================================
_REVIEW_LOCK_PATH = Path.home() / ".zcode" / "zcode-bridge-review.lock"


class ReviewFileLock:
    """跨进程文件锁 (fcntl.flock)。with 块内串行执行; 拿不到锁超时返回。"""

    def __init__(self, timeout=300):
        self.timeout = timeout
        self.enabled = os.environ.get("ZCODE_BRIDGE_REVIEW_LOCK", "1") != "0"
        self.fd = None

    def __enter__(self):
        if not self.enabled:
            return self
        self.fd = open(_REVIEW_LOCK_PATH, "w")
        t0 = time.time()
        while True:
            try:
                fcntl.flock(self.fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
                return self  # 拿到锁
            except (OSError, BlockingIOError):
                if time.time() - t0 > self.timeout:
                    self.fd.close()
                    self.fd = None
                    raise TimeoutError(f"review 锁等待超时 ({self.timeout}s), 可能有并发 review 在跑")
                time.sleep(0.5)

    def __exit__(self, *exc):
        if self.fd is not None:
            try:
                fcntl.flock(self.fd, fcntl.LOCK_UN)
            except OSError:
                pass
            self.fd.close()


