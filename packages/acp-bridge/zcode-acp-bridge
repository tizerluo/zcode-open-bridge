#!/usr/bin/env python3
"""
zcode-acp-bridge — 把 headless ZCode 桥接为 ACP (Agent Client Protocol) Agent

让 Zed / JetBrains 等 ACP 兼容编辑器能通过标准 ACP 协议调用 zcode (GLM-5.2)。

工作原理 (双模式自动选择):
  ACP Client (编辑器)            zcode-acp-bridge              zcode app-server
       │                              │                              │
       │  ACP initialize              │                              │
       │─────────────────────────────▶│  (直接响应, 声明 capability)   │
       │                              │                              │
       │  ACP session/new             │  zcode session/create        │
       │─────────────────────────────▶│─────────────────────────────▶│
       │  {sessionId}                 │◀─────────────────────────────│
       │◀─────────────────────────────│                              │
       │                              │                              │
       │  ACP session/prompt          │  zcode session/subscribe     │
       │─────────────────────────────▶│─────────────────────────────▶│
       │                              │  register listener            │
       │                              │  zcode session/send           │
       │                              │─────────────────────────────▶│
       │                              │                              │
       │                              │  session/event 推送:          │
       │                              │  model.streaming → 流式文本   │
       │                              │  tool.updated → 工具状态      │
       │                              │  turn.completed → 收尾        │
       │                              │◀─────────────────────────────│
       │                              │                              │
       │  session/update (流式)       │                              │
       │  agent_message_chunk (逐段)  │                              │
       │  tool_call / tool_call_update│                              │
       │◀─────────────────────────────│                              │
       │  session/prompt result       │                              │
       │  {stopReason: end_turn}      │                              │
       │◀─────────────────────────────│                              │

  若 session/subscribe 不可用 (旧版 CLI <0.14.8): 自动降级为轮询 session/read,
  turn 完成后整段发文本 (伪流式)。

能力范围:
  ✅ initialize 握手
  ✅ session/new → session/create
  ✅ session/prompt → 事件驱动真流式 (0.14.8+) / 轮询伪流式 (旧版降级)
  ✅ 流式文本 (model.streaming → agent_message_chunk 逐段)
  ✅ 工具调用展示 (tool.updated → tool_call/tool_call_update 实时)
  ✅ session/cancel → session/stop
  ✅ 扩展方法: fork/rewind/goal/compact/steer (0.14.8+)

协议: ACP (JSON-RPC 2.0 over stdio) 对外; ZCode Protocol (无 jsonrpc 字段) 对内
依赖: 仅 Python3 标准库
"""

import json
import os
import queue
import subprocess
import sys
import threading
import time
import uuid
from pathlib import Path

# ============================================================
# 配置
# ============================================================
ACP_PROTOCOL_VERSION = 1
BRIDGE_INFO = {"name": "zcode-acp-bridge", "title": "ZCode (GLM-5.2)", "version": "1.0.0"}
ZCODE_BIN = os.environ.get("ZCODE_BIN", "zcode")
ZCODE_CREDS_PATH = Path.home() / ".zcode" / "v2" / "config.json"


def log(msg):
    """日志走 stderr, 绝不污染 stdout 协议流"""
    print(f"[zcode-acp] {msg}", file=sys.stderr, flush=True)


def load_zcode_credentials():
    """从 v2/config.json 动态读取凭证 (不明文存储)。

    NOTE: 本函数源自 shared/credentials.py (权威实现), 修改时请同步。
    """
    try:
        with open(ZCODE_CREDS_PATH) as f:
            cfg = json.load(f)
        for _pid, p in cfg.get("provider", {}).items():
            if p.get("enabled"):
                opts = p.get("options", {})
                models = p.get("models", {})
                return {
                    "ZCODE_MODEL": next(iter(models)) if models else "GLM-5.2",
                    "ZCODE_BASE_URL": opts.get("baseURL", ""),
                    "ANTHROPIC_API_KEY": opts.get("apiKey", ""),
                }
    except Exception as e:
        log(f"读取凭证失败: {e}")
    return {}


# ============================================================
# ZCode app-server 的 client 封装
# ============================================================
class ZCodeBackend:
    """管理 zcode app-server 子进程, 后台 reader 线程分发消息。

    消息分三种, 由后台 _reader_loop 读取并路由:
      - 响应 (有 id):          → _response_queues[id] 的 Queue
      - session/event 推送:     → 当前 _event_listener 的 Queue
      - 其他 notification:      → _notification_queue
    """

    def __init__(self):
        env = {**os.environ, **load_zcode_credentials()}
        self.proc = subprocess.Popen(
            [ZCODE_BIN, "app-server", "--stdio"],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
            text=True, bufsize=1, env=env,
        )
        # send 与 close 用同一把锁保护子进程管道
        self._send_lock = threading.Lock()
        # 响应路由: msg_id → Queue; request() 注册后读, 收到后清理
        self._response_queues = {}
        self._resp_lock = threading.Lock()
        # 通用 notification 队列 (非 session/event 的 notification)
        self._notification_queue = queue.Queue()
        # 当前事件监听器: {zcode_sid: EventStreamListener}
        self._event_listeners = {}
        self._listeners_lock = threading.Lock()
        # reader 线程健康标志: 退出后设 True, request() 快速失败而非慢速假死
        self._reader_dead = False
        self._reader_stop = False
        self._reader_thread = threading.Thread(target=self._reader_loop, daemon=True)
        self._reader_thread.start()
        log(f"已启动 zcode app-server (pid={self.proc.pid})")

    def _reader_loop(self):
        """后台线程: 持续读 zcode stdout, 按消息类型分发到对应队列。"""
        while not self._reader_stop:
            try:
                line = self.proc.stdout.readline()
                if not line:
                    break  # 进程关闭
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue
                method = msg.get("method")
                msg_id = msg.get("id")
                if msg_id is not None and method is None:
                    # 响应: 有 id 无 method → 路由到对应 Queue
                    with self._resp_lock:
                        q = self._response_queues.pop(msg_id, None)
                    if q is not None:
                        q.put(msg)
                    else:
                        # 没人等: 放通用队列兜底
                        self._notification_queue.put(msg)
                elif method == "session/event":
                    # 事件推送: 路由到对应会话的 listener
                    ev = msg.get("params", {})
                    sid = ev.get("sessionId")
                    with self._listeners_lock:
                        listener = self._event_listeners.get(sid)
                    if listener is not None:
                        listener.handle_event(ev)
                    else:
                        # 没人监听: 忽略 (订阅是按需的)
                        pass
                elif method is not None:
                    # 其他 notification (如 state.updated) → 通用队列
                    self._notification_queue.put(msg)
                else:
                    # 带有 id 和 method 的消息 (不常见), 当响应处理
                    with self._resp_lock:
                        q = self._response_queues.pop(msg_id, None)
                    if q is not None:
                        q.put(msg)
            except Exception as e:
                log(f"reader 线程异常: {e}")
                break
        # reader 退出: 设标志, 后续 request() 快速失败而非慢速假死
        self._reader_dead = True
        # 清理所有等待中的响应队列, 让它们立即得到错误
        with self._resp_lock:
            for q in self._response_queues.values():
                q.put({"error": {"message": "zcode backend reader exited"}})
            self._response_queues.clear()
        log("reader 线程退出 (backend 已标记为 dead)")

    def register_event_listener(self, zcode_sid, listener):
        """注册事件监听器, 之后该 sid 的 session/event 会路由到它。"""
        with self._listeners_lock:
            self._event_listeners[zcode_sid] = listener

    def unregister_event_listener(self, zcode_sid):
        """注销事件监听器。"""
        with self._listeners_lock:
            self._event_listeners.pop(zcode_sid, None)

    def send(self, msg):
        """发一条消息给 zcode (无 jsonrpc 字段)"""
        with self._send_lock:
            self.proc.stdin.write(json.dumps(msg, ensure_ascii=False) + "\n")
            self.proc.stdin.flush()

    def readline(self, timeout=2.0):
        """[兼容旧调用] 从通用 notification 队列读一条消息。

        注: reader 线程模式下, 所有响应走 request(), 所有 notification 走队列。
        旧代码中 readline 直接读 stdout 的用法已被 request() 取代。
        """
        try:
            return self._notification_queue.get(timeout=timeout)
        except queue.Empty:
            return None

    def request(self, msg_id, method, params=None, timeout=30):
        """同步请求: 注册响应队列, 发送, 等待对应 id 的响应。

        期间到达的其他 notification 由 reader 线程异步分发到各自的队列,
        不会被本方法吞掉 (修复旧版 request 与事件推送的竞态)。
        """
        if params is None:
            params = {}
        # reader 已死: 快速失败, 不让调用方卡满 timeout
        if self._reader_dead:
            return {"error": {"message": "zcode backend reader exited (backend dead)"}}, []
        # 注册响应队列
        resp_q = queue.Queue()
        with self._resp_lock:
            self._response_queues[msg_id] = resp_q
        try:
            self.send({"id": msg_id, "method": method, "params": params})
        except (BrokenPipeError, OSError) as e:
            with self._resp_lock:
                self._response_queues.pop(msg_id, None)
            self._reader_dead = True
            return {"error": {"message": f"zcode backend pipe broken: {e}"}}, []
        try:
            resp = resp_q.get(timeout=timeout)
            return resp, []  # notifications 已由 reader 分发, 不再在这里收集
        except queue.Empty:
            with self._resp_lock:
                self._response_queues.pop(msg_id, None)
            return {"error": {"message": "timeout"}}, []

    def close(self):
        self._reader_stop = True
        try:
            self.proc.terminate()
            self.proc.wait(timeout=3)
        except Exception:
            self.proc.kill()


# ============================================================
# TurnMonitor: 把轮询循环抽离, 每次返回完整快照 (不只 status)
# ============================================================
class TurnMonitor:
    """封装 session/read 轮询, 提供完整 projection 快照。

    解决 MVP 里轮询只取 status 就 break、丢弃其他字段的问题。
    """

    def __init__(self, backend, zcode_sid, bridge):
        self.backend = backend
        self.zcode_sid = zcode_sid
        self.bridge = bridge  # 用于 _next_id / _drain_inbox

    def poll_once(self):
        """发一次 session/read, 返回 projection dict 或 None。

        注: reader 线程模式下用 request() 拿响应 (不再直接 readline)。
        """
        poll_id = self.bridge._next_id()
        resp, _ = self.backend.request(poll_id, "session/read",
                                       {"sessionId": self.zcode_sid}, timeout=5)
        if "error" not in resp:
            return resp.get("result", {}).get("projection", {})
        return None


# ============================================================
# EventStreamListener: 订阅 zcode 事件流 (session/subscribe + session/event)
# ============================================================
# 新版 ZCode (CLI 0.14.8+) 增加了事件推送机制:
#   session/subscribe(deliveryKind=desktop-continuous) 开启推送
#   之后服务器主动发 {method:"session/event", params:{type, payload, seq, ...}}
#   流式文本通过 model.streaming 事件 (kind=text_delta) 逐段推送, 不再等 turn 结束。
class EventStreamListener:
    """订阅 zcode 事件流, 把 session/event 推送入队供主循环消费。

    用法:
      listener = EventStreamListener(backend, zcode_sid)
      snapshot = listener.subscribe()        # 订阅, 返回初始快照 (或 None 降级)
      if snapshot is not None:
          backend.register_event_listener(zcode_sid, listener)
          # ... 主循环里 listener.poll_event() 取事件 ...
          backend.unregister_event_listener(zcode_sid)
    """

    def __init__(self, backend, zcode_sid):
        self.backend = backend
        self.sid = zcode_sid
        self.last_seq = 0               # seq 游标
        self.subscribed = False
        self._event_queue = queue.Queue()

    def subscribe(self, msg_id):
        """调 session/subscribe 拿初始快照 + eventSeq 水位线。

        返回: snapshot dict (含 projection/messages) 或 None (失败, 调用方应降级轮询)。
        """
        resp, _ = self.backend.request(msg_id, "session/subscribe", {
            "sessionId": self.sid,
            "deliveryKind": "desktop-continuous",
            "includeSnapshot": True,
            "afterSeq": 0,
        }, timeout=10)
        if "error" in resp:
            log(f"  session/subscribe 失败 (降级轮询): {resp['error'].get('message', '')}")
            return None
        result = resp.get("result", {})
        self.last_seq = result.get("eventSeq", 0)
        self.subscribed = True
        log(f"  ✓ session/subscribe 成功 (eventSeq={self.last_seq})")
        return result.get("snapshot")

    def handle_event(self, event):
        """被 ZCodeBackend._reader_loop 调用: 把 session/event params 入队。"""
        seq = event.get("seq", self.last_seq)
        if seq > self.last_seq:
            self.last_seq = seq
        self._event_queue.put(event)

    def poll_event(self, timeout=0.5):
        """取一条事件, 超时返回 None。"""
        try:
            return self._event_queue.get(timeout=timeout)
        except queue.Empty:
            return None


# ============================================================
# EventTranslator: 把 zcode 事件 → ACP 事件 dict (复用 ProjectionDiffer 的 kind)
# ============================================================
# 实测 zcode 事件类型 (session/event params.type):
#   turn.started      → 标记 turn 启动
#   model.streaming   → 流式文本/推理增量 (payload.kind=text_delta/reasoning_delta)
#   tool.updated      → 工具调用 (payload.kind=scheduled/started/progress/result/batch)
#   turn.completed    → turn 完成 (payload.usage/tokenCount/resultType)
#   turn.failed       → turn 失败
class EventTranslator:
    """把 zcode session/event 翻译成 ACP 事件 dict 列表。

    输出格式与 ProjectionDiffer.diff() 一致 (kind 标识), 可直接喂给 _dispatch_event。
    """

    # zcode tool 名 → ACP ToolKind (复用 ProjectionDiffer 的映射)
    TOOL_KIND_MAP = {
        "Bash": "execute", "bash": "execute",
        "Edit": "edit", "Write": "edit", "edit": "edit", "write": "edit",
        "Read": "read", "read": "read",
        "Grep": "search", "grep": "search", "Glob": "search",
        "WebFetch": "fetch", "WebSearch": "fetch", "web_search": "fetch",
    }

    def __init__(self):
        self.turn_started = False
        self.turn_done = False
        self.turn_result_type = None     # success/cancelled/error_...
        self._seen_tool_ids = set()      # 已通知过的 toolCallId (scheduled)
        self._tool_names = {}             # call_id → tool_name (result 事件不带 toolName)

    def translate(self, event):
        """翻译一条 zcode event → ACP 事件 dict 列表 (可能为空)。

        Args:
            event: session/event 的 params (含 type, payload, seq)。
        Returns:
            list of event dict (kind 格式, 同 ProjectionDiffer)。
        """
        etype = event.get("type", "")
        payload = event.get("payload") or {}
        results = []

        if etype == "turn.started":
            self.turn_started = True
            log("  [event] turn.started")

        elif etype == "model.streaming":
            results.extend(self._translate_streaming(payload))

        elif etype == "tool.updated":
            results.extend(self._translate_tool(payload))

        elif etype == "turn.completed":
            self.turn_done = True
            self.turn_result_type = payload.get("resultType", "success")
            results.extend(self._translate_turn_done(payload))
            log(f"  [event] turn.completed (resultType={self.turn_result_type})")

        elif etype == "turn.failed":
            self.turn_done = True
            self.turn_result_type = payload.get("resultType", "error")
            log(f"  [event] turn.failed (resultType={self.turn_result_type})")

        # 其他类型 (session.updated/titleUpdated 等) 不产出 ACP 事件
        return results

    def _translate_streaming(self, payload):
        """model.streaming → TextDelta / ReasoningDelta (逐段增量)。"""
        results = []
        kind = payload.get("kind", "")
        delta = payload.get("delta", "")
        if not delta:
            return results
        if kind == "text_delta":
            results.append({"kind": "TextDelta", "text": delta})
        elif kind == "reasoning_delta":
            results.append({"kind": "ReasoningDelta", "text": delta})
        return results

    def _translate_tool(self, payload):
        """tool.updated → ToolCallNew / ToolCallUpdate。"""
        results = []
        tkind = payload.get("kind", "")
        call_id = payload.get("toolCallId", "")
        tool_name = payload.get("toolName", "")

        if tkind == "scheduled":
            if call_id and call_id not in self._seen_tool_ids:
                self._seen_tool_ids.add(call_id)
                self._tool_names[call_id] = tool_name
                acp_kind = self.TOOL_KIND_MAP.get(tool_name, "execute")
                results.append({
                    "kind": "ToolCallNew",
                    "call_id": call_id,
                    "tool": tool_name or "unknown",
                    "acp_kind": acp_kind,
                    "status": "pending",
                })

        elif tkind == "started":
            if call_id:
                results.append({
                    "kind": "ToolCallUpdate",
                    "call_id": call_id,
                    "status": "in_progress",
                })

        elif tkind == "progress":
            if call_id:
                # progress 事件含 stdoutTail/stderrTail (实时输出)
                output = payload.get("stdoutTail", "") or payload.get("stderrTail", "")
                results.append({
                    "kind": "ToolCallUpdate",
                    "call_id": call_id,
                    "status": "in_progress",
                    "output": output,
                })

        elif tkind == "result":
            if call_id:
                output = payload.get("result", "")
                results.append({
                    "kind": "ToolCallUpdate",
                    "call_id": call_id,
                    "status": "completed",
                    "output": str(output)[:2000] if output else "",
                })

        elif tkind == "error":
            if call_id:
                results.append({
                    "kind": "ToolCallUpdate",
                    "call_id": call_id,
                    "status": "failed",
                    "output": payload.get("error", ""),
                })

        elif tkind == "batch":
            # batch: 多个工具一起完成。payload 含 toolCallIds[] + successCount/errorCount。
            # 实测 zcode 通常也会逐个发 result, 但作为兜底: 若 batch 里有未完成的 call_id,
            # 补发 completed, 防止工具在编辑器里永远卡在 in_progress。
            batch_ids = payload.get("toolCallIds", [])
            error_count = payload.get("errorCount", 0)
            for bid in batch_ids:
                # 只补发 scheduled 过的 (避免给未知 id 发幽灵事件)
                if bid in self._seen_tool_ids:
                    results.append({
                        "kind": "ToolCallUpdate",
                        "call_id": bid,
                        "status": "failed" if error_count > 0 else "completed",
                    })
        return results

    def _translate_turn_done(self, payload):
        """turn.completed → UsageDelta (最终用量)。"""
        results = []
        usage = payload.get("usage") or {}
        token_count = payload.get("tokenCount", 0)
        used = usage.get("totalTokens") or token_count or 0
        size = usage.get("contextWindow", 0)
        if size > 0 or used > 0:
            results.append({"kind": "UsageDelta", "used": used, "size": size})
        return results


# ============================================================
# ProjectionDiffer: 对比两次快照, 输出事件列表
# ============================================================
# 事件类型 (dataclass 太重, 用简单 dict + "kind" 标识)
# ToolCallNew:    {kind, call_id, tool, status, input, output}
# ToolCallUpdate: {kind, call_id, status, output}
# UsageDelta:     {kind, used, size}
# TextDelta:      {kind, text}
# ReasoningDelta: {kind, text}
# PlanUpdate:     {kind, entries:[{content,status,priority}]}
# FilesChanged:   {kind, files:[str]}

class ProjectionDiffer:
    """对比两次快照差异, 产出事件列表。

    快照来源: session/read 的 projection (含 activeToolCalls/totalTokenCount 等)
    辅以 session/messages 的 parts (text/tool/reasoning/patch/todo)。
    """

    # zcode tool 名 → ACP ToolKind 映射
    TOOL_KIND_MAP = {
        "Bash": "execute", "bash": "execute",
        "Edit": "edit", "Write": "edit", "edit": "edit", "write": "edit",
        "Read": "read", "read": "read",
        "Grep": "search", "grep": "search", "Glob": "search",
        "WebFetch": "fetch", "WebSearch": "fetch", "web_search": "fetch",
    }

    # zcode tool state.status → ACP ToolCallStatus
    TOOL_STATUS_MAP = {
        "pending": "pending", "running": "in_progress",
        "completed": "completed", "error": "failed",
    }

    def __init__(self):
        self._seen_tool_ids = set()      # 已通知过的 toolCallId
        self._last_tool_status = {}      # call_id → 上次 status
        self._last_usage = None          # 上次 totalTokenCount
        self._seen_message_ids = set()   # 已处理过的 message id (避免多轮/resume 误发历史)
        self._last_plan_sig = "__none__" # 上次 plan 签名 (初始 "__none__" 让首次空 todos 也能发出清空事件)
        self._seen_patch_hashes = set()  # 已通知过的 patch hash
        self.emitted_text_this_turn = False  # 本轮是否已发过 TextDelta (兜底判断用)

    def mark_seen(self, messages):
        """把给定 messages 全部标记为已见 (建立 baseline, 避免误发历史)。"""
        for m in messages:
            key = self._message_dedup_key(m)
            if key:
                self._seen_message_ids.add(key)

    @staticmethod
    def _message_dedup_key(m):
        """生成消息去重键。优先 info.id; 无 id 时用 (role, parts 内容签名) 做 fallback。

        修复 P3: 原代码无 id 消息每次 diff 都重发。zcode 协议保证 info.id 存在
        (实测验证), 但 fallback 让代码对边界情况也安全, 且注释与行为一致。
        """
        info = m.get("info", {}) if isinstance(m.get("info"), dict) else {}
        msg_id = info.get("id") or m.get("id")
        if msg_id:
            return msg_id
        # fallback: role + parts 内容签名 (无 id 时用, 避免重复)
        role = info.get("role", "?")
        parts = m.get("parts", [])
        try:
            parts_sig = json.dumps(parts, ensure_ascii=False, sort_keys=True)[:200]
        except (TypeError, ValueError):
            parts_sig = str(parts)[:200]
        return f"__fallback::{role}::{parts_sig}"

    def reset_turn(self):
        """每个 turn 开始时重置"本轮"标记 (不重置 _seen_message_ids)。"""
        self.emitted_text_this_turn = False

    def diff(self, prev_snapshot, cur_snapshot):
        """对比两次快照。snapshot = {projection, messages, todos}。

        返回事件列表 (可能为空)。

        关键: 只处理"本轮新增"的消息 (按 message id 去重), 避免多轮/resume 时
        把历史 assistant 回复当新增重发。text/reasoning 按整条消息发 (zcode 快照式,
        每条 assistant 消息是完整的, 不存在跨 snapshot 增量)。
        """
        events = []
        cur_proj = cur_snapshot.get("projection", {}) if cur_snapshot else {}
        cur_msgs = cur_snapshot.get("messages", []) if cur_snapshot else []

        # 1. usage_update: totalTokenCount / contextWindow 变化
        used = cur_proj.get("totalTokenCount", 0)
        size = cur_proj.get("contextWindow", 0)
        if self._last_usage is None or used != self._last_usage:
            if size > 0:  # 首次或变化才发
                events.append({"kind": "UsageDelta", "used": used, "size": size})
            self._last_usage = used

        # 2. 只遍历"本轮新增"的 messages (去重, 修复 P1.1 误发历史 + P3 无 id 重复)
        for m in cur_msgs:
            dedup_key = self._message_dedup_key(m)
            # 按 dedup_key 去重: 优先 info.id; 无 id 时用 (role, parts 内容) 做 fallback
            if dedup_key and dedup_key in self._seen_message_ids:
                continue
            if dedup_key:
                self._seen_message_ids.add(dedup_key)
            role = m.get("info", {}).get("role")
            for p in m.get("parts", []):
                if not isinstance(p, dict):
                    continue
                ptype = p.get("type")
                if ptype == "tool":
                    events.extend(self._diff_tool_part(p))
                elif ptype == "text" and role == "assistant":
                    # 整条 text 发送 (新消息才到这里, 已按 id 去重)
                    text = p.get("text", "")
                    if text.strip():
                        events.append({"kind": "TextDelta", "text": text})
                        self.emitted_text_this_turn = True
                elif ptype == "reasoning":
                    text = p.get("text", "")
                    if text.strip():
                        events.append({"kind": "ReasoningDelta", "text": text})
                elif ptype == "patch":
                    ph = p.get("hash")
                    if ph and ph not in self._seen_patch_hashes:
                        self._seen_patch_hashes.add(ph)
                        events.append({"kind": "FilesChanged", "files": p.get("files", [])})

        # 3. plan (todos) — 含清空: todos 变空也要发空列表 (修复 P2.3)
        todos = cur_snapshot.get("todos", []) or []
        sig = json.dumps(todos, ensure_ascii=False, sort_keys=True)
        if sig != self._last_plan_sig:
            self._last_plan_sig = sig
            entries = [{"content": t.get("content", ""),
                        "status": t.get("status", "pending"),
                        "priority": t.get("priority", "medium")}
                       for t in todos]
            events.append({"kind": "PlanUpdate", "entries": entries})

        return events

    def _diff_tool_part(self, p):
        """对比单个 tool part, 产出 ToolCallNew / ToolCallUpdate 事件"""
        events = []
        call_id = p.get("callID") or p.get("callId")
        if not call_id:
            return events
        tool_name = p.get("tool", "other")
        state = p.get("state", {})
        status = state.get("status", "pending")

        if call_id not in self._seen_tool_ids:
            # 新工具调用
            self._seen_tool_ids.add(call_id)
            self._last_tool_status[call_id] = status
            events.append({
                "kind": "ToolCallNew",
                "call_id": call_id,
                "tool": tool_name,
                "status": self.TOOL_STATUS_MAP.get(status, "other"),
                "input": state.get("input"),
                "output": state.get("output") if status in ("completed",) else None,
                "title": f"{tool_name}: {self._summarize_input(state.get('input'))}",
            })
        else:
            # 状态更新
            if status != self._last_tool_status.get(call_id):
                self._last_tool_status[call_id] = status
                update = {
                    "kind": "ToolCallUpdate",
                    "call_id": call_id,
                    "status": self.TOOL_STATUS_MAP.get(status, "other"),
                }
                if status in ("completed", "error"):
                    update["output"] = state.get("output") or state.get("error")
                events.append(update)
        return events

    @staticmethod
    def _summarize_input(inp):
        """生成人类可读的 input 摘要"""
        if inp is None:
            return ""
        if isinstance(inp, dict):
            # 取 command / path / pattern 等关键字段
            for k in ("command", "path", "pattern", "query", "file_path"):
                if k in inp:
                    return str(inp[k])[:60]
            return json.dumps(inp, ensure_ascii=False)[:60]
        return str(inp)[:60]


# ============================================================
# ACP 桥接器主逻辑
# ============================================================
class ACPBridge:
    def __init__(self):
        self.backend = None
        # 映射: ACP sessionId → zcode sessionId (实际上两边格式一致, 但保留映射以防变化)
        self.session_map = {}
        # 当前进行中的 prompt: {acp_prompt_id: {zcode_sid, cancelled, perms_responses}}
        self.pending_turns = {}
        # id 基数提到 10_000_000, 避免与 zcode 主动请求的 id 空间冲突
        self._msg_counter = 10_000_000
        # stdin 消息队列: 后台线程把每行 stdin 入队, 主循环/轮询循环从队列取
        # 这解决了 run() 单线程阻塞导致 cancel/permission 响应读不到的问题
        self._inbox = queue.Queue()
        self._stdin_thread = None

    def _next_id(self):
        self._msg_counter += 1
        return self._msg_counter

    def ensure_backend(self):
        if self.backend is None:
            self.backend = ZCodeBackend()

    # ---------- ACP 协议层 (对外) ----------

    def handle_acp(self, req):
        """处理来自 ACP client 的一条请求, 返回响应 dict 或 None"""
        method = req.get("method")
        msg_id = req.get("id")

        # notification (无 id) 不需要响应
        if msg_id is None and method and method.startswith("notifications/"):
            return None

        if method == "initialize":
            return self._on_initialize(msg_id, req.get("params", {}))

        if method == "session/new":
            return self._on_session_new(msg_id, req.get("params", {}))

        if method == "session/prompt":
            return self._on_session_prompt(msg_id, req.get("params", {}))

        if method == "session/cancel":
            return self._on_session_cancel(req.get("params", {}))

        if method == "session/list":
            return self._on_session_list(msg_id, req.get("params", {}))

        if method == "session/resume":
            return self._on_session_resume(msg_id, req.get("params", {}))

        # ===== 扩展方法 (非标准 ACP, 透传 zcode 新版协议) =====
        # 这些方法不在 ACP baseline 中, 是 zcode-specific 的能力暴露。
        if method == "session/fork":
            return self._on_session_fork(msg_id, req.get("params", {}))
        if method == "session/rewind":
            return self._on_session_rewind(msg_id, req.get("params", {}))
        if method == "session/goal":
            return self._on_session_goal(msg_id, req.get("params", {}))
        if method == "session/compact":
            return self._on_session_compact(msg_id, req.get("params", {}))
        if method == "session/steer":
            return self._on_session_steer(msg_id, req.get("params", {}))

        # 未实现的 method
        if method and msg_id is not None:
            return self._error(msg_id, -32601, f"Method not supported: {method}")
        return None

    def _on_initialize(self, msg_id, params):
        """ACP initialize: 协商版本, 声明最小 capability"""
        client_pv = params.get("protocolVersion", ACP_PROTOCOL_VERSION)
        log(f"initialize: client protocolVersion={client_pv}, client={params.get('clientInfo',{}).get('name')}")

        return {
            "jsonrpc": "2.0", "id": msg_id,
            "result": {
                "protocolVersion": ACP_PROTOCOL_VERSION,
                "agentCapabilities": {
                    "loadSession": False,
                    "promptCapabilities": {"image": False, "audio": False, "embeddedContext": False},
                    "mcpCapabilities": {"http": False, "sse": False},
                    "sessionCapabilities": {"list": {}, "resume": {}},
                    "auth": {},
                },
                "agentInfo": BRIDGE_INFO,
                "authMethods": [],
            },
        }

    def _on_session_new(self, msg_id, params):
        """ACP session/new → zcode session/create"""
        self.ensure_backend()
        cwd = params.get("cwd") or os.getcwd()
        log(f"session/new: cwd={cwd}")

        zc_id = self._next_id()
        # mode=yolo: 跳过工具权限确认, 否则 build 模式下工具调用 turn 会卡在 pendingPermissions
        resp, _ = self.backend.request(zc_id, "session/create", {
            "workspace": {"workspacePath": cwd, "workspaceKey": cwd},
            "mode": "yolo",
        }, timeout=15)

        if "error" in resp:
            return self._error(msg_id, -32603, f"zcode create failed: {resp['error'].get('message','')}")

        zcode_sid = resp.get("result", {}).get("session", {}).get("sessionId")
        if not zcode_sid:
            return self._error(msg_id, -32603, "zcode create returned no sessionId")

        # ACP sessionId: 用 zcode 的或生成一个
        acp_sid = zcode_sid  # 格式兼容, 直接用
        self.session_map[acp_sid] = zcode_sid
        log(f"session/new → {acp_sid}")

        return {"jsonrpc": "2.0", "id": msg_id, "result": {"sessionId": acp_sid}}

    def _on_session_list(self, msg_id, params):
        """ACP session/list → zcode session/list, 转成 ACP SessionInfo[]"""
        self.ensure_backend()
        cwd = params.get("cwd")
        zc_params = {"includeArchived": params.get("includeArchived", False)}
        if cwd:
            zc_params["workspace"] = {"workspacePath": cwd, "workspaceKey": cwd}
        limit = params.get("limit")
        if limit:
            zc_params["limit"] = limit

        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/list", zc_params, timeout=15)
        if "error" in resp:
            return self._error(msg_id, -32603, f"zcode list failed: {resp['error'].get('message','')}")

        zc_sessions = resp.get("result", {}).get("sessions", [])
        # 转成 ACP SessionInfo: {sessionId, cwd, title?, updatedAt?}
        acp_sessions = []
        for s in zc_sessions:
            ws = s.get("workspace", {})
            acp_sessions.append({
                "sessionId": s.get("sessionId", ""),
                "cwd": ws.get("workspacePath", ""),
                "title": s.get("title"),
                "updatedAt": self._to_iso(s.get("updatedAt")),
            })
        log(f"session/list → {len(acp_sessions)} sessions")
        return {"jsonrpc": "2.0", "id": msg_id, "result": {"sessions": acp_sessions}}

    def _on_session_resume(self, msg_id, params):
        """ACP session/resume → zcode session/resume, 记录映射"""
        self.ensure_backend()
        target_sid = params.get("sessionId")
        cwd = params.get("cwd") or os.getcwd()
        if not target_sid:
            return self._error(msg_id, -32602, "sessionId required")

        zc_params = {"sessionId": target_sid,
                     "workspace": {"workspacePath": cwd, "workspaceKey": cwd}}
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/resume", zc_params, timeout=15)
        if "error" in resp:
            return self._error(msg_id, -32603, f"zcode resume failed: {resp['error'].get('message','')}")

        # resume 成功: 记录映射 (zcode sessionId 与 ACP 一致)
        self.session_map[target_sid] = target_sid
        log(f"session/resume → {target_sid}")
        return {"jsonrpc": "2.0", "id": msg_id, "result": {}}

    # ---------- 扩展方法 (非标准 ACP, 透传 zcode 新版协议 0.14.8+) ----------
    # 以下方法不在 ACP baseline 中, 暴露 zcode-specific 能力。
    # 编辑器/脚本可通过这些方法调用 fork/rewind/goal/compact/steer。

    def _on_session_fork(self, msg_id, params):
        """扩展 session/fork → zcode session/fork: 从 checkpoint 分叉新会话。

        params: {sessionId, target?}
          target: 默认 {kind:"latestCheckpoint"}; 或 {kind:"checkpoint", checkpointId}
        """
        self.ensure_backend()
        acp_sid = params.get("sessionId")
        zcode_sid = self.session_map.get(acp_sid) or acp_sid
        zc_params = {"sessionId": zcode_sid}
        # target 默认 latestCheckpoint; 显式 checkpointId 则构造 {kind, checkpointId}
        if params.get("checkpointId"):
            zc_params["target"] = {"kind": "checkpoint", "checkpointId": params["checkpointId"]}
        else:
            zc_params["target"] = params.get("target", {"kind": "latestCheckpoint"})
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/fork", zc_params, timeout=15)
        if "error" in resp:
            return self._error(msg_id, -32603,
                               f"zcode fork failed: {resp['error'].get('message', '')}")
        result = resp.get("result", {})
        new_sid = result.get("sessionId")
        if new_sid:
            self.session_map[new_sid] = new_sid
        log(f"session/fork → {new_sid or '?'}")
        return {"jsonrpc": "2.0", "id": msg_id, "result": result}

    def _on_session_rewind(self, msg_id, params):
        """扩展 session/rewind → zcode session/rewind: 回退工作区文件到 checkpoint。

        params: {sessionId, target?, expectedRevision?}
          target: 默认 {kind:"latestCheckpoint"}; 或 {kind:"checkpoint", checkpointId}
        """
        self.ensure_backend()
        acp_sid = params.get("sessionId")
        zcode_sid = self.session_map.get(acp_sid) or acp_sid
        zc_params = {"sessionId": zcode_sid}
        if params.get("checkpointId"):
            zc_params["target"] = {"kind": "checkpoint", "checkpointId": params["checkpointId"]}
        else:
            zc_params["target"] = params.get("target", {"kind": "latestCheckpoint"})
        if params.get("expectedRevision") is not None:
            zc_params["expectedRevision"] = params["expectedRevision"]
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/rewind", zc_params, timeout=15)
        if "error" in resp:
            return self._error(msg_id, -32603,
                               f"zcode rewind failed: {resp['error'].get('message', '')}")
        result = resp.get("result", {})
        log("session/rewind → ok")
        return {"jsonrpc": "2.0", "id": msg_id, "result": result}

    def _on_session_goal(self, msg_id, params):
        """扩展 session/goal → zcode session/goal: 读取或设置 session 目标。

        params: {sessionId, action?, objective?}
          - action 默认 "show" (读取); "set" 设置; "replace" 替换; "clear" 清除; "pause"/"resume" 暂停/恢复
          - objective: 目标文本 (action=set/replace 时必填)

        注意: action=set/replace 会启动内部 AI turn (异步), 必须等待其完成
        否则后续调用会报 "Cannot manage goals while a prompt is running"。
        """
        self.ensure_backend()
        acp_sid = params.get("sessionId")
        zcode_sid = self.session_map.get(acp_sid) or acp_sid
        action = params.get("action", "show")
        zc_params = {"sessionId": zcode_sid, "action": action}
        if action in ("set", "replace") and params.get("objective") is not None:
            zc_params["objective"] = params["objective"]
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/goal", zc_params, timeout=15)
        if "error" in resp:
            return self._error(msg_id, -32603,
                               f"zcode goal failed: {resp['error'].get('message', '')}")
        result = resp.get("result", {})
        # set/replace 启动内部 turn, 等待其 prompt lock 释放 (用 goal show 探测)
        # 实测 goal set 的内部 AI turn 耗时 10-45s+ 不等, 必须等锁释放
        # 否则后续 show/compact 会报 "prompt is running"
        if action in ("set", "replace"):
            released = self._wait_for_turn_idle(zcode_sid, timeout=60, probe_method="session/goal")
            if released:
                log(f"session/goal action={action} → ok (内部 turn lock 已释放)")
            else:
                log(f"session/goal action={action} → ok (⚠ lock 等待超时, 后续 show/compact 可能暂不可用)")
        else:
            log(f"session/goal action={action} → ok")
        return {"jsonrpc": "2.0", "id": msg_id, "result": result}

    def _on_session_compact(self, msg_id, params):
        """扩展 session/compact → zcode session/compact: 压缩对话上下文。

        params: {sessionId}
        注: compact 本身是同步的 (返回 snapshot), 不启动内部 turn。
        但若前一个 goal set 的内部 turn 仍在跑, compact 会报 "prompt is running"。
        goal set handler 已等待 lock 释放, 所以正常流程不会撞此问题。
        """
        self.ensure_backend()
        acp_sid = params.get("sessionId")
        zcode_sid = self.session_map.get(acp_sid) or acp_sid
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/compact",
                                       {"sessionId": zcode_sid}, timeout=30)
        if "error" in resp:
            return self._error(msg_id, -32603,
                               f"zcode compact failed: {resp['error'].get('message', '')}")
        result = resp.get("result", {})
        log("session/compact → ok")
        return {"jsonrpc": "2.0", "id": msg_id, "result": result}

    def _on_session_steer(self, msg_id, params):
        """扩展 session/steer → zcode session/steer: turn 进行中追加指令。

        params: {sessionId, content}
        注意: steer 只在 turn 运行中有效; 无活动 turn 时会返回错误。
        """
        self.ensure_backend()
        acp_sid = params.get("sessionId")
        zcode_sid = self.session_map.get(acp_sid) or acp_sid
        content = params.get("content", "")
        if not content.strip():
            return self._error(msg_id, -32602, "steer 需要 content")
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/steer",
                                       {"sessionId": zcode_sid, "content": content}, timeout=15)
        if "error" in resp:
            return self._error(msg_id, -32603,
                               f"zcode steer failed: {resp['error'].get('message', '')}")
        result = resp.get("result", {})
        log(f"session/steer → kind={result.get('kind', '?')}")
        return {"jsonrpc": "2.0", "id": msg_id, "result": result}

    @staticmethod
    def _to_iso(ts):
        """zcode 的毫秒时间戳 → ISO 8601 字符串 (ACP SessionInfo.updatedAt 期望)"""
        if not ts:
            return None
        try:
            from datetime import datetime, timezone
            return datetime.fromtimestamp(ts / 1000, tz=timezone.utc).isoformat()
        except Exception:
            return None

    def _wait_for_turn_idle(self, zcode_sid, timeout=45, probe_method=None):
        """等待 zcode 会话的内部 turn 完成后 lock 释放。

        session/goal(set)、session/compact 等方法会启动内部 AI turn,
        它们在 request() 返回后仍在后台运行。projection.status=idle 并不
        意味着内部 prompt lock 已释放 (实测 goal set 后 status 很快变 idle,
        但 "prompt is running" lock 持续 10-25s)。因此可靠的方式是:
        重试一个探测调用直到不再报 "while a prompt is running"。

        Args:
            zcode_sid: zcode 会话 ID
            timeout: 最大等待秒数
            probe_method: 可选, 探测用的 zcode 方法 (如 "session/goal" show)。
                          若为 None 则用 session/read 轮询 status。
        Returns:
            True 若 lock 已释放; False 超时。
        """
        t0 = time.time()
        if probe_method:
            # 用探测调用重试, 直到不再报 "prompt is running"
            while time.time() - t0 < timeout:
                probe_id = self._next_id()
                resp, _ = self.backend.request(probe_id, probe_method,
                                               {"sessionId": zcode_sid, "action": "show"},
                                               timeout=10)
                if "error" not in resp:
                    log(f"  [probe] lock 已释放 (elapsed {round(time.time()-t0,1)}s)")
                    return True  # lock 已释放
                err_msg = resp.get("error", {}).get("message", "")
                # timeout 或 "prompt is running" 都继续等; 其他错误视为释放
                if "prompt is running" in err_msg or "timeout" in err_msg.lower():
                    time.sleep(2)
                    continue
                log(f"  [probe] 非锁错误, 视为释放: {err_msg[:50]}")
                return True
            log(f"  [probe] 等待超时 ({timeout}s), lock 可能仍占用")
            return False
        else:
            # fallback: 轮询 status
            monitor = TurnMonitor(self.backend, zcode_sid, self)
            while time.time() - t0 < timeout:
                proj = monitor.poll_once()
                if proj and proj.get("status") == "idle":
                    time.sleep(1)
                    return True
                time.sleep(0.5)
            return False

    def _on_session_prompt(self, msg_id, params):
        """ACP session/prompt → zcode session/send + 监听 state.updated + 返回

        这是桥接器的核心: 把 zcode 的异步模型转成 ACP 的阻塞模型。
        """
        acp_sid = params.get("sessionId")
        zcode_sid = self.session_map.get(acp_sid)
        if not zcode_sid:
            return self._error(msg_id, -32603, f"unknown session: {acp_sid}")

        # 从 ACP prompt (ContentBlock[]) 提取文本 + resource_link (修复 P2.2)
        # ACP baseline 要求支持 text 和 resource_link 两种
        prompt_blocks = params.get("prompt", [])
        text_parts = []
        for block in prompt_blocks:
            if not isinstance(block, dict):
                continue
            btype = block.get("type")
            if btype == "text":
                text_parts.append(block.get("text", ""))
            elif btype == "resource_link":
                # resource_link 含 uri/title; 转成路径提示让 zcode 知道有相关资源
                uri = block.get("uri", "")
                title = block.get("title", "")
                if uri:
                    text_parts.append(f"[相关资源: {title}]({uri})" if title else f"[相关资源] {uri}")
        prompt_text = "\n".join(text_parts)

        if not prompt_text.strip():
            return self._error(msg_id, -32602, "empty prompt (需 text 或 resource_link)")

        log(f"session/prompt: sid={acp_sid[:20]}..., text={prompt_text[:40]!r}")

        # 注册 pending turn (供 cancel 查询)
        turn = {"zcode_sid": zcode_sid, "cancelled": False}
        self.pending_turns[msg_id] = turn

        # 建立 baseline: send 前先记录已有消息 id, 让 differ 只产出本轮新增 (修复 P1.1)
        # differ 跨 turn 持久化 (按 session 存), 避免多轮/resume 误发历史
        differ = self._get_or_create_differ(zcode_sid)
        # 先喂一次当前 messages, 让 _seen_message_ids 标记所有历史消息为"已见"
        baseline_msgs = self._fetch_messages(zcode_sid)
        if baseline_msgs:
            differ.mark_seen(baseline_msgs)
        chunk_msg_id = f"msg_{uuid.uuid4().hex[:12]}"

        # ===== 双模式: 优先事件驱动, 失败降级轮询 =====
        # 新版 ZCode (0.14.8+) 支持 session/subscribe 推送流式事件 (model.streaming)。
        # 事件驱动模式下: model.streaming → 逐段 TextDelta (真流式);
        #                tool.updated → 实时工具调用状态。
        # 降级模式 (旧版 CLI / subscribe 失败): 轮询 session/read, turn 结束整段发 (伪流式)。

        # ⚠️ 时序关键: 必须先 subscribe + register listener, 再 session/send。
        # 否则 send 和 register 之间的 session/event 会被 reader 线程丢弃,
        # 短 turn 的 turn.completed 可能丢失导致 120s 超时。
        listener = EventStreamListener(self.backend, zcode_sid)
        sub_id = self._next_id()
        snapshot = listener.subscribe(sub_id)

        if snapshot is not None:
            # 事件驱动模式: 先注册 listener (确保不丢事件), 再 send
            self.backend.register_event_listener(zcode_sid, listener)
            try:
                # 现在 send prompt (listener 已注册, 不会丢事件)
                zc_id = self._next_id()
                resp, _ = self.backend.request(zc_id, "session/send",
                                               {"sessionId": zcode_sid, "content": prompt_text},
                                               timeout=10)
                if "error" in resp:
                    del self.pending_turns[msg_id]
                    return self._error(msg_id, -32603,
                                       f"zcode send failed: {resp['error'].get('message', '')}")
                if not resp.get("result", {}).get("accepted", False):
                    del self.pending_turns[msg_id]
                    return self._error(msg_id, -32603, "zcode send 未被接受 (无 accepted 响应)")

                result = self._run_event_turn(
                    listener, acp_sid, zcode_sid, msg_id, turn, chunk_msg_id, differ)
            finally:
                self.backend.unregister_event_listener(zcode_sid)
            return result
        else:
            # 降级: 轮询模式 — send 在轮询循环前发
            zc_id = self._next_id()
            resp, _ = self.backend.request(zc_id, "session/send",
                                           {"sessionId": zcode_sid, "content": prompt_text},
                                           timeout=10)
            if "error" in resp:
                del self.pending_turns[msg_id]
                return self._error(msg_id, -32603,
                                   f"zcode send failed: {resp['error'].get('message', '')}")
            if not resp.get("result", {}).get("accepted", False):
                del self.pending_turns[msg_id]
                return self._error(msg_id, -32603, "zcode send 未被接受 (无 accepted 响应)")
            log("  ⟳ 降级轮询模式 (事件流不可用)")
            return self._run_polling_turn(
                acp_sid, zcode_sid, msg_id, turn, chunk_msg_id, differ)

    def _run_event_turn(self, listener, acp_sid, zcode_sid, msg_id, turn, chunk_msg_id, differ):
        """事件驱动 turn 循环: 消费 session/event 推送, 翻译成 ACP 事件实时发。

        真流式: model.streaming 的 text_delta 逐段发为 agent_message_chunk。
        """
        translator = EventTranslator()
        t0 = time.time()
        emitted_text = False   # 本轮是否已通过事件发过文本 (用于决定兜底)
        last_event_time = time.time()
        last_stall_check = 0   # 上次停滞检查的时间戳 (可重复检查)

        while time.time() - t0 < 120:
            # 每轮先处理 inbox: 让 session/cancel 真正生效
            self._drain_inbox()
            if turn["cancelled"]:
                self._cancel_backend_turn(zcode_sid)
                del self.pending_turns[msg_id]
                return {"jsonrpc": "2.0", "id": msg_id,
                        "result": {"stopReason": "cancelled"}}

            # 从事件队列取一条 (超时 0.5s)
            event = listener.poll_event(timeout=0.5)
            if event is None:
                # 无事件。如果 turn 已启动且超过 15s 无事件,
                # 可能 turn.completed 事件丢失 → 用 session/read 确认并轮询收尾。
                # 每 15s 可重复检查 (长静默 turn 不会只查一次就放弃)。
                if translator.turn_started \
                        and time.time() - last_event_time > 15 \
                        and time.time() - last_stall_check > 15:
                    last_stall_check = time.time()
                    log("  ⚠ 事件流停滞, 用 session/read 确认 turn 状态")
                    monitor = TurnMonitor(self.backend, zcode_sid, self)
                    proj = monitor.poll_once()
                    if proj and proj.get("status") == "idle":
                        log("  ✓ 确认 turn 已完成 (事件可能丢失), 收尾")
                        del self.pending_turns[msg_id]
                        # 停滞收尾: 不调 differ.diff() (differ 不知道事件路径已发过什么,
                        # 会重复发 TextDelta/tool 事件)。只做兜底: 若事件路径未发文本,
                        # 用 _fetch_last_reply 取最后回复。
                        if not emitted_text:
                            reply_text = self._fetch_last_reply(zcode_sid, differ)
                            if reply_text:
                                self._send_acp_notification("session/update", {
                                    "sessionId": acp_sid,
                                    "update": {"sessionUpdate": "agent_message_chunk",
                                               "content": {"type": "text", "text": reply_text},
                                               "messageId": chunk_msg_id},
                                })
                        return {"jsonrpc": "2.0", "id": msg_id,
                                "result": {"stopReason": "end_turn"}}
                continue

            last_event_time = time.time()

            # 翻译事件 → ACP 事件 dict 列表
            acp_events = translator.translate(event)
            for ev in acp_events:
                # 标记: 是否已通过 model.streaming 发过文本
                if ev.get("kind") == "TextDelta":
                    emitted_text = True
                self._dispatch_event(ev, acp_sid, chunk_msg_id)

            # turn 结束判定
            if translator.turn_done:
                del self.pending_turns[msg_id]
                result_type = translator.turn_result_type
                if result_type == "cancelled":
                    return {"jsonrpc": "2.0", "id": msg_id,
                            "result": {"stopReason": "cancelled"}}
                if result_type and result_type.startswith("error_"):
                    log(f"session/prompt: turn 失败 ({result_type})")
                    return self._error(msg_id, -32603, f"zcode turn failed: {result_type}")

                # turn 正常完成。若未收到任何 text_delta (如纯工具调用 turn), 兜底发最后回复
                if not emitted_text:
                    reply_text = self._fetch_last_reply(zcode_sid, differ)
                    if reply_text:
                        self._send_acp_notification("session/update", {
                            "sessionId": acp_sid,
                            "update": {
                                "sessionUpdate": "agent_message_chunk",
                                "content": {"type": "text", "text": reply_text},
                                "messageId": chunk_msg_id,
                            },
                        })
                    log(f"session/prompt 完成 (事件): stopReason=end_turn, "
                        f"{'兜底' if not emitted_text else '流式'} 回复")
                else:
                    log("session/prompt 完成 (事件): stopReason=end_turn, 流式文本已发")

                return {"jsonrpc": "2.0", "id": msg_id,
                        "result": {"stopReason": "end_turn"}}

        # 超时
        del self.pending_turns[msg_id]
        log("session/prompt 超时: 事件模式下 120s 未完成")
        return {"jsonrpc": "2.0", "id": msg_id,
                "result": {"stopReason": "max_turn_requests"}}

    def _run_polling_turn(self, acp_sid, zcode_sid, msg_id, turn, chunk_msg_id, differ):
        """轮询降级 turn 循环: 轮询 session/read 检测 status, turn 完成整段发事件。

        这是旧版 ZCode (无事件推送) 的兼容模式。
        """
        monitor = TurnMonitor(self.backend, zcode_sid, self)
        last_usage = None
        t0 = time.time()
        last_status = None
        turn_started = False
        consecutive_none = 0   # 连续 poll 失败计数
        turn_completed = False
        while time.time() - t0 < 120:
            # 每轮先处理 inbox: 让 session/cancel 真正生效
            self._drain_inbox()
            if turn["cancelled"]:
                self._cancel_backend_turn(zcode_sid)
                del self.pending_turns[msg_id]
                return {"jsonrpc": "2.0", "id": msg_id,
                        "result": {"stopReason": "cancelled"}}

            projection = monitor.poll_once()
            status = projection.get("status") if projection else None

            if projection is None:
                consecutive_none += 1
                if consecutive_none >= 10:  # 连续 ~5s 无响应
                    log(f"  ⚠ 连续 {consecutive_none} 次 poll 失败")
                time.sleep(0.5)
                continue
            consecutive_none = 0

            # 轻量 usage_update (只读 projection, 不调 messages)
            if turn_started:
                used = projection.get("totalTokenCount", 0)
                size = projection.get("contextWindow", 0)
                if last_usage is None or used != last_usage:
                    if size > 0:
                        self._dispatch_event({"kind": "UsageDelta", "used": used, "size": size},
                                             acp_sid, chunk_msg_id)
                    last_usage = used

            if status and status != last_status:
                log(f"  轮询 status: {status} (elapsed {round(time.time()-t0,1)}s)")
                last_status = status

            # 状态机: 先等 running (turn 启动), 再等 idle (turn 完成)
            if status == "running":
                turn_started = True
            elif status == "idle" and turn_started:
                log("  ✓ turn 完成 (status=idle)")
                # turn 完成: 取一次完整 snapshot, 发本轮新增的 tool/text/reasoning/plan 事件
                cur_snapshot = self._build_snapshot(zcode_sid, projection)
                events = differ.diff(None, cur_snapshot)
                for ev in events:
                    self._dispatch_event(ev, acp_sid, chunk_msg_id)
                turn_completed = True
                break

            time.sleep(0.5)  # 轮询间隔

        # turn 未完成 (超时或从未 running)
        del self.pending_turns[msg_id]
        if not turn_completed:
            if not turn_started:
                log("session/prompt 失败: turn 从未启动 (status 未变 running)")
                return self._error(msg_id, -32603, "zcode turn 未启动 (可能后端繁忙或拒绝)")
            log("session/prompt 超时: turn 启动但 120s 未完成")
            return {"jsonrpc": "2.0", "id": msg_id,
                    "result": {"stopReason": "max_turn_requests"}}

        # turn 正常完成。differ 已发本轮新增 text; 若本轮无新增 text, 兜底发最后一条 assistant 回复
        if not differ.emitted_text_this_turn:
            differ.emitted_text_this_turn = False  # reset
            reply_text = self._fetch_last_reply(zcode_sid, differ)
            if reply_text:
                self._send_acp_notification("session/update", {
                    "sessionId": acp_sid,
                    "update": {
                        "sessionUpdate": "agent_message_chunk",
                        "content": {"type": "text", "text": reply_text},
                        "messageId": chunk_msg_id,
                    },
                })
            log(f"session/prompt 完成: stopReason=end_turn, 回复 {len(reply_text)} 字 (兜底)")
        else:
            differ.emitted_text_this_turn = False  # reset for next turn
            log("session/prompt 完成: stopReason=end_turn, text 已随事件发送")

        return {"jsonrpc": "2.0", "id": msg_id,
                "result": {"stopReason": "end_turn"}}

    # ---------- differ 管理 + 后端交互辅助 ----------

    def _get_or_create_differ(self, zcode_sid):
        """获取或创建 session 级别的 ProjectionDiffer (跨 turn 持久化)。

        修复 P1.1: differ 按 session 存, 不每 turn 新建, 避免多轮/resume 误发历史。
        """
        if not hasattr(self, "_differs"):
            self._differs = {}
        if zcode_sid not in self._differs:
            self._differs[zcode_sid] = ProjectionDiffer()
        d = self._differs[zcode_sid]
        d.reset_turn()  # 重置"本轮"标记
        return d

    def _fetch_messages(self, zcode_sid):
        """取 session/messages 的消息列表 (建 baseline / 兜底用)。"""
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/messages",
                                       {"sessionId": zcode_sid}, timeout=8)
        if "result" in resp:
            return resp["result"].get("messages", [])
        return []

    def _cancel_backend_turn(self, zcode_sid):
        """向 zcode 后端转发取消 (修复 P2.1: 不能只本地标记)。

        zcode 的取消 method 是 session/stop。即使失败也不阻塞 (本地标记已生效)。
        """
        try:
            zc_id = self._next_id()
            self.backend.send({"id": zc_id, "method": "session/stop",
                               "params": {"sessionId": zcode_sid}})
            log(f"  → 已向后端发 session/stop (sid={zcode_sid[:16]}...)")
        except Exception as e:
            log(f"  → session/stop 发送失败 (忽略): {e}")

    def _on_session_cancel(self, params):
        """ACP session/cancel: 标记当前 turn 取消 (本地), 后端取消由轮询循环检测到标记后转发"""
        acp_sid = params.get("sessionId")
        for tid, turn in self.pending_turns.items():
            if turn["zcode_sid"] == self.session_map.get(acp_sid):
                turn["cancelled"] = True
                log(f"session/cancel: 标记 turn {tid} 取消")
                break
        return None  # notification, 无响应

    def _fetch_last_reply(self, zcode_sid, differ=None):
        """turn 完成后, 读 session/messages 拿最后一条 assistant 回复的文本。

        修复 P1: 传入 differ, 只返回 differ 尚未见过的 assistant 文本,
        避免把上一轮旧回复当兜底发出。若所有 assistant 消息都已见过, 返回 ""
        (本轮可能是 tool-only/patch-only, 不应强发旧文本)。

        zcode 在 status=idle 后, messages 可能有数据一致性延迟, 故用短 retry。
        """
        for _attempt in range(4):  # 最多重试 4 次
            zc_id = self._next_id()
            resp, _ = self.backend.request(zc_id, "session/messages",
                                           {"sessionId": zcode_sid}, timeout=10)
            if "error" in resp or "result" not in resp:
                time.sleep(0.4)
                continue
            messages = resp["result"].get("messages", [])
            # 找最后一条 differ 未见的 assistant 消息
            for m in reversed(messages):
                info = m.get("info", {})
                if info.get("role") != "assistant":
                    continue
                # 若传了 differ, 跳过已见消息 (避免兜底旧回复)
                if differ is not None:
                    key = differ._message_dedup_key(m)
                    if key and key in differ._seen_message_ids:
                        continue
                parts = m.get("parts", [])
                texts = [p.get("text", "") for p in parts
                         if isinstance(p, dict) and p.get("type") == "text"]
                text = "\n".join(texts)
                if text.strip():  # 拿到非空且未见的文本才返回
                    return text
            time.sleep(0.4)  # 还没数据, 等一会再试
        return ""

    def _build_snapshot(self, zcode_sid, projection):
        """构造快照: projection + messages + todos。

        messages 来自 session/messages (含 parts: text/tool/reasoning/patch)。
        todos 来自 session/read 的 Om 顶层 (实测: session/messages 响应不含 todos)。
        """
        # messages (parts 数据源)
        zc_id = self._next_id()
        resp, _ = self.backend.request(zc_id, "session/messages",
                                       {"sessionId": zcode_sid}, timeout=5)
        messages = []
        if "result" in resp:
            messages = resp["result"].get("messages", [])
        # todos (来自 session/read 的 Om 顶层, 不在 messages 响应里)
        todos = []
        zc_id2 = self._next_id()
        resp2, _ = self.backend.request(zc_id2, "session/read",
                                        {"sessionId": zcode_sid}, timeout=5)
        if "result" in resp2:
            todos = resp2["result"].get("todos", []) or []
        return {"projection": projection or {}, "messages": messages, "todos": todos}

    def _dispatch_event(self, ev, acp_sid, chunk_msg_id):
        """把 ProjectionDiffer 产出的事件转成 ACP session/update notification。

        各能力的序列化逻辑隔离在此, 互不污染 _on_session_prompt。
        P0-P4 的 handler 都挂在这里。
        """
        kind = ev.get("kind")

        if kind == "ToolCallNew":
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid,
                "update": {
                    "sessionUpdate": "tool_call",
                    "toolCallId": ev["call_id"],
                    "title": ev.get("title", ev["tool"]),
                    "kind": ProjectionDiffer.TOOL_KIND_MAP.get(ev["tool"], "other"),
                    "status": ev.get("status"),
                    "rawInput": ev.get("input"),
                    "rawOutput": ev.get("output"),
                },
            })

        elif kind == "ToolCallUpdate":
            update = {
                "sessionUpdate": "tool_call_update",
                "toolCallId": ev["call_id"],
                "status": ev.get("status"),
            }
            if ev.get("output") is not None:
                update["rawOutput"] = ev["output"]
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid, "update": update,
            })

        elif kind == "UsageDelta":
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid,
                "update": {
                    "sessionUpdate": "usage_update",
                    "used": ev["used"],
                    "size": ev["size"],
                },
            })

        elif kind == "TextDelta":
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid,
                "update": {
                    "sessionUpdate": "agent_message_chunk",
                    "content": {"type": "text", "text": ev["text"]},
                    "messageId": chunk_msg_id,
                },
            })

        elif kind == "ReasoningDelta":
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid,
                "update": {
                    "sessionUpdate": "agent_thought_chunk",
                    "content": {"type": "text", "text": ev["text"]},
                    "messageId": f"thought_{chunk_msg_id}",
                },
            })

        elif kind == "PlanUpdate":
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid,
                "update": {
                    "sessionUpdate": "plan",
                    "entries": ev["entries"],
                },
            })

        elif kind == "FilesChanged":
            # P4a diff 降级: zcode 协议层无 oldText/newText, 只能列文件名
            files = ev.get("files", [])
            self._send_acp_notification("session/update", {
                "sessionId": acp_sid,
                "update": {
                    "sessionUpdate": "tool_call",
                    "toolCallId": f"files_{uuid.uuid4().hex[:8]}",
                    "title": f"变更文件 ({len(files)}): {', '.join(files[:3])}{'...' if len(files)>3 else ''}",
                    "kind": "edit",
                    "status": "completed",
                    "content": [{"type": "content",
                                 "content": {"type": "text",
                                             "text": "影响的文件:\n" + "\n".join(files)}}],
                },
            })

    # ---------- 工具方法 ----------

    def _send_acp_notification(self, method, params):
        """向 ACP client 发 notification (无 id)"""
        msg = {"jsonrpc": "2.0", "method": method, "params": params}
        sys.stdout.write(json.dumps(msg, ensure_ascii=False) + "\n")
        sys.stdout.flush()

    def _error(self, msg_id, code, message):
        return {"jsonrpc": "2.0", "id": msg_id,
                "error": {"code": code, "message": message}}

    def _stdin_reader(self):
        """后台线程: 把 stdin 每行入队, 让轮询循环也能读到 cancel/permission 响应"""
        for line in sys.stdin:
            self._inbox.put(line)

    def _drain_inbox(self):
        """轮询循环每轮调用: 处理 inbox 里的 cancel / permission 响应等"带外"消息。

        注意: session/prompt 等"需响应"的请求不在这里处理 (它们会阻塞主循环),
        这里只处理 notification (session/cancel) 和对 pending permission 的响应。
        """
        while True:
            try:
                line = self._inbox.get_nowait()
            except queue.Empty:
                return
            line = line.strip()
            if not line:
                continue
            try:
                req = json.loads(line)
            except json.JSONDecodeError:
                continue
            method = req.get("method")
            msg_id = req.get("id")
            # session/cancel: 标记对应 turn 取消
            if method == "session/cancel":
                acp_sid = req.get("params", {}).get("sessionId")
                for tid, turn in self.pending_turns.items():
                    if turn.get("zcode_sid") == self.session_map.get(acp_sid):
                        turn["cancelled"] = True
                        log(f"[inbox] session/cancel: 标记 turn {tid} 取消")
                continue
            # 带 id 的消息: 视为对 pending permission 的响应, 存入 turn
            if msg_id is not None:
                for turn in self.pending_turns.values():
                    turn.setdefault("perm_responses", {})[msg_id] = req
                continue
            # 其他 notification: 暂忽略

    def run(self):
        """主循环: 后台线程读 stdin 入队, 主循环从队列取消息处理"""
        log(f"启动 zcode-acp-bridge, ACP protocol v{ACP_PROTOCOL_VERSION}, agent={BRIDGE_INFO['name']}")
        self._stdin_thread = threading.Thread(target=self._stdin_reader, daemon=True)
        self._stdin_thread.start()
        while True:
            try:
                line = self._inbox.get(timeout=1.0)
            except queue.Empty:
                if not self._stdin_thread.is_alive():
                    break
                continue
            line = line.strip()
            if not line:
                continue
            try:
                req = json.loads(line)
            except json.JSONDecodeError:
                self._send_acp_notification("rpc/error", {"code": -32700, "message": "Parse error"})
                continue
            try:
                resp = self.handle_acp(req)
                if resp is not None:
                    sys.stdout.write(json.dumps(resp, ensure_ascii=False) + "\n")
                    sys.stdout.flush()
            except Exception as e:
                log(f"处理异常: {e}")
                err = self._error(req.get("id"), -32603, str(e))
                sys.stdout.write(json.dumps(err, ensure_ascii=False) + "\n")
                sys.stdout.flush()
        log("stdin 关闭, 退出")
        if self.backend:
            self.backend.close()


def main():
    bridge = ACPBridge()
    try:
        bridge.run()
    except KeyboardInterrupt:
        log("中断")
    finally:
        if bridge.backend:
            bridge.backend.close()


if __name__ == "__main__":
    main()
