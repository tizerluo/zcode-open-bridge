def print_pretty(cap):
    v = cap["environment"]["zcode_version"]
    print(f"╔══ ZCode v{v} — 开放生态能力说明书 ══╗\n")
    print(cap["what_it_is"], "\n")

    print("▼ 三层架构")
    for layer in cap["three_layers"]:
        print(f"  [{layer['layer']}] {layer['name']}")
        print(f"    {layer['summary']}")
        print(f"    入口: {layer['entry']}\n")

    # native_cli
    nc = cap["native_cli"]
    print("▼ 第一层: 原生 Headless CLI")
    print("  必需环境变量: ZCODE_MODEL / ZCODE_BASE_URL / ANTHROPIC_API_KEY")
    print(f"  ⚠ {nc['config_note'][:60]}...\n")
    for m in nc["headless_modes"]:
        print(f"  [{m['name']}] {m['description']}")
        print(f"    用法: {m['usage']}\n")
    by_cat = {}
    for c in nc["capabilities"]:
        by_cat.setdefault(c["category"], []).append(c)
    for cat, items in by_cat.items():
        print(f"  · {cat}能力")
        for c in items:
            st = "✅" if c.get("supported", True) else "❌"
            print(f"    {st} {c['name']}: {c['description']}")
    print(f"\n  限制: {len(nc['known_limitations'])} 项\n")

    # app_server
    aps = cap["app_server"]
    print("▼ 第二层: App Server 协议")
    print(f"  {aps['description'][:70]}...")
    print(f"  关键 method: {', '.join(m['method'] for m in aps['key_methods'][:5])}...")
    print(f"  part 类型: {', '.join(aps['part_types'].keys())}\n")

    # ecosystem
    eco = cap["ecosystem"]
    print("▼ 第三层: 开放生态接入")
    for comp in eco["components"]:
        print(f"  [{comp['maturity']}] {comp['name']}: {comp['role']}")
    print(f"  会话存储: {'共享' if eco['session_storage']['shared'] else '独立'} "
          f"({eco['session_storage']['location'][:40]}...)\n")

    # environment
    env = cap["environment"]
    print("▼ 当前环境 (动态探测)")
    print(f"  zcode 版本: {env['zcode_version']}")
    print(f"  已装 skill: {env['skills_count']} 个")
    print(f"  已装组件: {[k for k,v in env['installed_components'].items() if v] or '无'}")


def main():
    args = sys.argv[1:]
    if "--help" in args or "-h" in args:
        print(__doc__)
        return 0

    if "--section" in args:
        idx = args.index("--section")
        if idx + 1 < len(args):
            section = args[idx + 1]
            # 静态 section 直接查 SECTIONS; environment 是动态探测的, 单独处理
            if section == "environment":
                data = discover_environment()
            else:
                data = SECTIONS.get(section)
            if data is not None:
                print(json.dumps(data, indent=2, ensure_ascii=False))
                return 0
            print(f"未知 section: {section}\n可用: {', '.join(list(SECTIONS.keys()) + ['environment'])}",
                  file=sys.stderr)
            return 1

    cap = build_full()
    if "--pretty" in args:
        print_pretty(cap)
        return 0

    print(json.dumps(cap, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    sys.exit(main())
