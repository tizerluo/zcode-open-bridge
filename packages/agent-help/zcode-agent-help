# ============================================================
# 动态探测: 实时调用 zcode 获取当前环境信息
# ============================================================
def _run_zcode_json(args):
    try:
        result = subprocess.run(
            [ZCODE_BIN] + args + ["--json"],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode != 0:
            return None
        return json.loads(result.stdout)
    except (subprocess.TimeoutExpired, json.JSONDecodeError, FileNotFoundError):
        return None


def _get_version():
    try:
        result = subprocess.run(
            [ZCODE_BIN, "version"], capture_output=True, text=True, timeout=10
        )
        return result.stdout.strip() or "unknown"
    except Exception:
        return "unknown"


def discover_environment():
    env = {"zcode_version": _get_version()}

    skills_data = _run_zcode_json(["skills", "list"])
    if skills_data and "skills" in skills_data:
        env["installed_skills"] = [
            {"name": s.get("name"),
             "description": (s.get("description") or "").strip() or "(无描述)",
             "scope": s.get("scope"), "source": s.get("source")}
            for s in skills_data["skills"]
        ]
        env["skills_count"] = len(skills_data["skills"])
    else:
        env["installed_skills"] = []
        env["skills_count"] = 0

    cmds_data = _run_zcode_json(["commands", "list"])
    if cmds_data and isinstance(cmds_data, dict):
        cmds = cmds_data.get("commands") or cmds_data.get("data") or []
        env["custom_commands"] = [c.get("name", str(c)) if isinstance(c, dict) else str(c) for c in cmds]
    else:
        env["custom_commands"] = []

    # 探测桥接器是否已安装
    bin_dir = Path.home() / ".local" / "bin"
    env["installed_components"] = {}
    for comp in ("zcode-agent-help", "zcode-mcp-server", "zcode-acp-bridge"):
        env["installed_components"][comp] = (bin_dir / comp).exists()

    return env


